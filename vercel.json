{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/index.js" },
    { "source": "/assets/(.*)", "destination": "client/assets/$1" },
    { "source": "/(.*\\.[a-z0-9]+)$", "destination": "client/$1" },
    { "source": "/((?!api/).*)", "destination": "client/index.html" }
  ]
}
